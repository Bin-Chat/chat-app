# ========================================
# CHAT APP - ENVIRONMENT VARIABLES
# ========================================

# NODE ENVIRONMENT
NODE_ENV=development

# ========================================
# DATABASE
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=chatapp
DB_PASSWORD=chatapp_password_change_me
DB_DATABASE=chatapp

# PostgreSQL Connection String
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}

# ========================================
# REDIS
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ========================================
# JWT TOKENS
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# API GATEWAY
# ========================================
API_GATEWAY_PORT=3000
GATEWAY_URL=http://localhost:3000

# ========================================
# SERVICES PORTS
# ========================================
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
SOCIAL_SERVICE_PORT=3003
CHAT_SERVICE_PORT=8080
REALTIME_SERVICE_PORT=8081
PRESENCE_SERVICE_PORT=8082

# ========================================
# SERVICES URLS
# ========================================
AUTH_SERVICE_URL=http://localhost:${AUTH_SERVICE_PORT}
USER_SERVICE_URL=http://localhost:${USER_SERVICE_PORT}
SOCIAL_SERVICE_URL=http://localhost:${SOCIAL_SERVICE_PORT}
CHAT_SERVICE_URL=http://localhost:${CHAT_SERVICE_PORT}
REALTIME_SERVICE_URL=http://localhost:${REALTIME_SERVICE_PORT}
PRESENCE_SERVICE_URL=http://localhost:${PRESENCE_SERVICE_PORT}

# ========================================
# KAFKA / REDPANDA
# ========================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=chat-app
KAFKA_GROUP_ID=chat-app-group

# ========================================
# OBJECT STORAGE (Cloudflare R2)
# ========================================
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=chat-app-media
S3_REGION=auto

# ========================================
# FIREBASE (Push Notifications)
# ========================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your-private-key

# ========================================
# FRONTEND
# ========================================
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:8081
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# ========================================
# MONITORING
# ========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# CORS
# ========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ========================================
# EMAIL (Optional - for password reset)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@chatapp.com
