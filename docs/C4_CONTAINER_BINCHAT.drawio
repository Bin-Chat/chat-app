<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="c4-container-binchat-spaced" name="C4 Container - BinChat">
    <mxGraphModel dx="1900" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
