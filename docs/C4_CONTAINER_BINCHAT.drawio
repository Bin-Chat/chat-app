        <!-- Notes -->
        <mxCell id="kafka-note" value="Kafka event relationships:&lt;br&gt;1. Auth publishes notification.email&lt;br&gt;2. Notification consumes notification.email&lt;br&gt;3. Chat publishes chat.message.created&lt;br&gt;4. AI consumes chat.message.created&lt;br&gt;5. AI publishes ai.message.moderated / agent.bot_reply / typing&lt;br&gt;6. Chat consumes AI events&lt;br&gt;7. API Gateway consumes realtime events and emits Socket.IO&lt;br&gt;8. Upload publishes upload/media events" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#D6B656;align=left;verticalAlign=top;spacing=12;fontSize=12;" vertex="1" parent="1">
